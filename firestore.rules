rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Evidence collection - user-scoped
      match /evidence/{evidenceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Court orders - user-scoped
      match /court_orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Court order clauses - user-scoped
      match /court_order_clauses/{clauseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Breach logs - user-scoped
      match /breach_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Audit log - user-scoped, append-only (no deletes)
      match /audit_log/{entryId} {
        allow read, create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false; // Audit log is immutable
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
